# =============================================================================
# IronBark .gitignore
# =============================================================================

# ---- Secrets ---------------------------------------------------------------
.env
.env.local
*.env
!.env.example

# ---- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/
.eggs/

# ---- Virtual environments --------------------------------------------------
.venv/
venv/
env/
ENV/

# ---- Models (downloaded at runtime) ----------------------------------------
*.pt
*.onnx
*.pth
models/

# ---- Data (face embeddings = biometric, frames, benchmarks) ----------------
data/*.npy
data/*.pkl
data/*.json
data/benchmark_frames/
data/captures/

# ---- Captured images / saved frames ----------------------------------------
*.jpg
*.jpeg
*.png
*.gif
*.bmp
# Exception: keep documentation images
!docs/**/*.jpg
!docs/**/*.png
!assets/**/*.jpg
!assets/**/*.png

# ---- OS --------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---- IDE -------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Logs ------------------------------------------------------------------
*.log
logs/
