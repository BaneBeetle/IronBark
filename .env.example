# IronBark — example environment file
# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# ---- Network ---------------------------------------------------------------
# PC_IP = Mac/PC running the brain (perception, follower, VLM)
# PI_IP = Raspberry Pi running the PiDog
# Tip: Tailscale IPs are stable across networks — run `tailscale ip -4` on each
# device to get them. Local LAN IPs (192.168.x.x) work too if both devices
# are on the same WiFi.
PC_IP=<your-mac-ip>
PI_IP=<your-pi-ip>

# ---- Pi SSH (used by deploy.sh) --------------------------------------------
# PI_DEPLOY_PATH is relative to the Pi user's home (avoid `~` — bash expands
# tildes locally during variable assignment, which would point at your Mac).
PI_USER=<your-pi-username>
PI_DEPLOY_PATH=ironbark
